# ─── Database ────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=costincnva2016
DB_NAME=cluj_monitor
DB_HOST=localhost
DB_PORT=5432

# Full connection URL (used by SQLAlchemy and psycopg2)
DATABASE_URL=postgresql://cluj_user:cluj_pass_change_me@localhost:5432/cluj_monitor

# ─── External APIs ───────────────────────────────────────────────────────────
# Nominatim (OpenStreetMap reverse geocoding) — no key needed, just a user-agent
NOMINATIM_USER_AGENT=cluj-urban-monitor/1.0

# Open-Meteo — no key needed for free tier
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast

# ─── Model Weights Paths ─────────────────────────────────────────────────────
RTDETR_WEIGHTS=ml/weights/rtdetr_l_cluj.pt
EFFICIENTNET_WEIGHTS=ml/weights/efficientnet_b3_depth.pt
XGBOOST_WEIGHTS=ml/weights/xgboost_severity.json

# ─── Pipeline Settings ───────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.5
FRAME_EXTRACTION_INTERVAL=0.5
DEDUP_RADIUS_METERS=2.0
SURROUNDING_DENSITY_RADIUS_METERS=50
DAILY_PIPELINE_HOUR=22
DAILY_PIPELINE_MINUTE=0

# ─── City Config ─────────────────────────────────────────────────────────────
CITY_NAME=Cluj-Napoca
CITY_LAT=46.7712
CITY_LON=23.6236
CITY_OSM_RELATION_ID=29928

# ─── Paths ───────────────────────────────────────────────────────────────────
RAW_FOOTAGE_DIR=data/raw/footage
RAW_GPS_DIR=data/raw/gps_logs
PROCESSED_FRAMES_DIR=data/processed/frames
PROCESSED_METADATA_DIR=data/processed/metadata